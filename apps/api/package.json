{
  "name": "@sistema-ibanje/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/app.js",
  "scripts": {
    "build": "tsc",
    "predev": "pkill -f 'node.*--import t[s]x src/app\\.ts' || true",
    "dev": "node --watch --import tsx src/app.ts",
    "start": "node dist/app.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "db:studio": "dotenv -e ../../.env -- drizzle-kit studio",
    "db:push": "dotenv -e ../../.env -- drizzle-kit push",
    "db:reset": "dotenv -e ../../.env -- sh -c 'docker compose -f ../../docker-compose.dev.yml exec -T -e PGPASSWORD=$POSTGRES_PASSWORD postgres psql -U $POSTGRES_USER -d $POSTGRES_DB -c \"DROP SCHEMA public CASCADE; CREATE SCHEMA public;\"' && pnpm db:migrate && pnpm db:seed",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:prod": "tsx src/db/seed.prod.ts",
    "db:dump-fixtures": "tsx src/db/scripts/dump-fixtures.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/session": "^11.1.1",
    "@fastify/swagger": "^9.7.0",
    "@fontsource/noto-sans": "^5.2.10",
    "@fontsource/roboto": "^5.2.10",
    "@react-pdf/renderer": "^4.5.1",
    "@scalar/fastify-api-reference": "^1.55.3",
    "@sistema-ibanje/shared": "workspace:*",
    "argon2": "^0.44.0",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "file-type": "^22.0.1",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-pdf-tailwind": "^3.0.0",
    "redis": "^5.12.1",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "vitest": "^4.1.6"
  }
}
