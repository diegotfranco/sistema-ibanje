# ---------------------------------------------------------------
# Sistema Ibanje — production environment template
# Copy this file to .env.production and fill in every value.
# Do NOT commit .env.production. Do NOT put real secrets in this file.
# ---------------------------------------------------------------

# The public origin of the site (used for CORS + email links).
# Use https://your-domain.example behind TLS, or http://server-ip for plain HTTP.
PUBLIC_URL=http://localhost

# Logging
LOG_LEVEL=info

# Postgres
POSTGRES_DB=app_name
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Session + password hashing — both must be 32+ chars.
# Generate with: openssl rand -base64 48
SESSION_SECRET=change_me_to_a_random_string_of_at_least_32_characters
ARGON2_PEPPER=change_me_to_a_random_string_of_at_least_32_characters

# MinIO (object storage for expense receipts)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=receipts

# Email (Resend). EMAIL_FROM_NOREPLY must be a verified sender on your Resend domain.
# Format example: "Display Name <no-reply@your-domain.example>"
RESEND_API_KEY=re_xxx
EMAIL_FROM_NOREPLY="App Name <no-reply@example.com>"

# Backups (daily at 02:00 UTC)
BACKUP_BUCKET=backups
BACKUP_RETAIN_DAYS=30

# Cloudflare R2 offsite mirror (optional — leave blank to disable).
# R2_ENDPOINT is the S3 API endpoint shown on the token page, NOT the public bucket URL.
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY=
R2_SECRET_KEY=
