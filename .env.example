# Docker services
POSTGRES_DB=sistema_ibanje
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sistema_ibanje
REDIS_URL=redis://localhost:6379
SESSION_SECRET=change_me_to_a_random_string_of_at_least_32_characters
ARGON2_PEPPER=change_me_to_a_random_string_of_at_least_32_characters
