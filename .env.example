# This .env is for local development (used by both docker-compose.dev.yml and the API).
# For production, see .env.production.example and DEPLOY.md.

# Docker services
POSTGRES_DB=app_name
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_name
REDIS_URL=redis://localhost:6379
SESSION_SECRET=change_me_to_a_random_string_of_at_least_32_characters
ARGON2_PEPPER=change_me_to_a_random_string_of_at_least_32_characters

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM_NOREPLY="App Name <no-reply@example.com>"
FRONTEND_URL=http://localhost:5173

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=receipts

# Backups (daily 02:00 UTC, written to MinIO)
BACKUP_BUCKET=backups
BACKUP_RETAIN_DAYS=30
